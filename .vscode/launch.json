{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug executable 'oc_img_gen'",
			"cargo": {
				"args": [
					"build",
					"--bin=oc_img_gen",
					"--package=oc_img_gen"
				],
				"filter": {
					"name": "oc_img_gen",
					"kind": "bin"
				}
			},
			// "args": [
			// 	"-i=data/test.png",
			// 	"--begin=1m2s",
			// 	"--stream_size=120x60"
			// ],
			"args": [
				"-i=data/miss_rgb.mp4",
				"--mode=single",
				"--stream-size=120x60",
				"--end=1m"
			],
			"cwd": "${workspaceFolder}"
		},
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug unit tests in executable 'oc_img_gen'",
			"cargo": {
				"args": [
					"test",
					"--no-run",
					"--bin=oc_img_gen",
					"--package=oc_img_gen"
				],
				"filter": {
					"name": "oc_img_gen",
					"kind": "bin"
				}
			},
			"args": [
				"-i=data/miss_rgb.mp4",
				"--mode=single",
				"--stream-size=120x60",
				"--end=1m"
			],
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "(Windows) Launch",
			"type": "cppvsdbg",
			"request": "launch",
			"program": "${workspaceRoot}/target/debug/oc_img_gen.exe",
			"args": [
				"-i=data/miss_rgb.mp4",
				"--mode=single",
				"--stream-size=120x60",
				"--end=1m"
			],
			"cwd": "${workspaceFolder}",
		}
	]
}
