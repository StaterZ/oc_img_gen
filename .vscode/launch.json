	"version": "0.2.0",
	"configurations": [
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug executable 'oc_img_gen'",
			"cargo": {
				"args": [
					"build",
					"--bin=oc_img_gen",
					"--package=oc_img_gen"
				],
				"filter": {
					"name": "oc_img_gen",
					"kind": "bin"
				}
			},
			// "args": [
			// 	"-i=data/test.png",
			// 	"--begin=1m2s",
			// 	"--stream_size=120x60"
			// ],
			"args": [
				"--in-path=data/ltt.mp4",
				"--mode=single",
				"--begin=1m30s",
				"--end=1m55s",
				"--stream-size=120x60",
				"--out-path=C:/Users/admin/AppData/Roaming/.minecraft/minecraft_installs/modded_1.12.2/saves/open computers/opencomputers/188ea28f-87a0-465f-b78e-cd6d548efb47/ltt.szt"
			],
			"cwd": "${workspaceFolder}"
		},
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug unit tests in executable 'oc_img_gen'",
			"cargo": {
				"args": [
					"test",
					"--no-run",
					"--bin=oc_img_gen",
					"--package=oc_img_gen"
				],
				"filter": {
					"name": "oc_img_gen",
					"kind": "bin"
				}
			},
			"args": [
				"-i=data/test.png",
				"--mode=single",
				"--stream-size=120x60"
			],
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "(Windows) Launch",
			"type": "cppvsdbg",
			"request": "launch",
			"program": "${workspaceRoot}/target/debug/oc_img_gen.exe",
			"args": [
				"-in_path=data/test.png",
				"--mode=single",
				"--stream-size=120x60"
			],
			"cwd": "${workspaceFolder}",
		}
	]
}
