{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug executable 'oc_img_gen'",
			"cargo": {
				"args": [
					"build",
					"--bin=oc_img_gen",
					"--package=oc_img_gen"
				],
				"filter": {
					"name": "oc_img_gen",
					"kind": "bin"
				}
			},
			"args": [
				"play",
				"-i=data/kill_v_maim.szt",
			],
			"cwd": "${workspaceFolder}"
		},
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug unit tests in executable 'oc_img_gen'",
			"cargo": {
				"args": [
					"test",
					"--no-run",
					"--bin=oc_img_gen",
					"--package=oc_img_gen"
				],
				"filter": {
					"name": "oc_img_gen",
					"kind": "bin"
				}
			},
			"args": [
				"play",
				"-i=data/kill_v_maim.szt",
			],
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "(Windows) Launch",
			"type": "cppvsdbg",
			"request": "launch",
			"program": "${workspaceRoot}/target/debug/oc_img_gen.exe",
			"args": [
				"play",
				"-i=data/kill_v_maim.szt",
			],
			"cwd": "${workspaceFolder}",
		}
	]
}
