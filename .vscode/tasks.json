{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "process",
			"command": "cargo",
			"args": [
				"run",
				"--features=rayon",
				//"--features=debug-mode",
				"--",
				"play",
				"-i=data/bad-apple.szt",
				"--matrix-screen-size=4x4"
			],
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"options": {
				"env": {
					"RUST_BACKTRACE": "1"
				}
			},
			"label": "rust: cargo run",
			"presentation": {
				"clear": true
			}
		}
	]
}
